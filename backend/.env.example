# Sentinel-X Backend — Environment Variables
# ===========================================
# Copy this file to .env and fill in real values.
# NEVER commit the actual .env file with secrets.

# Application
APP_NAME=Sentinel-X Core API
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# Network
HOST=0.0.0.0
PORT=8080

# Database (PostgreSQL via Supabase or self-hosted)
DATABASE_URL=postgresql://sentinel:CHANGE_ME@localhost:5432/sentinelx

# Redis Telemetry Cache
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_SECONDS=30

# MQTT Broker
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883

# AI / Model Paths
YOLO_MODEL_PATH=models/yolov11s-ppe.onnx
RISK_MODEL_PATH=models/risk_field_v3.pb

# PLC / Modbus (Fog Node address)
PLC_HOST=192.168.1.200
PLC_PORT=502
PLC_UNIT_ID=1

# Security (change this in production!)
SECRET_KEY=CHANGE_ME_USE_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=480
